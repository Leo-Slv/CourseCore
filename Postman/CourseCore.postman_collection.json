                "value": "{{correlationId}}"
              }
            ],
            "url": "{{baseUrl}}/api/courses/{{courseId}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  if (json.modules && json.modules.length > 0) {",
                  "    pm.environment.set(\"moduleId\", json.modules[0].id);",
                  "    if (json.modules[0].lessons && json.modules[0].lessons.length > 0) {",
                  "      pm.environment.set(\"lessonId\", json.modules[0].lessons[0].id);",
                  "    }",
                  "  }",
                  "}"
                ]
              }
            }
          ]
        },
