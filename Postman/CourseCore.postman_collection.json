{
  "info": {
    "_postman_id": "0c28d830-56c0-4d48-8ff1-140e9289d344",
    "name": "CourseCore API",
    "description": "Colecao para testar os endpoints HTTP da CourseCore API. Importe tambem o environment CourseCore Local e rode Auth/Login antes dos endpoints protegidos.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "noauth"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.environment.set(\"correlationId\", pm.variables.replaceIn(\"{{$guid}}\"));"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.test(\"Response has correlation id header\", function () {",
          "  pm.expect(pm.response.headers.has(\"X-Correlation-ID\")).to.eql(true);",
          "});"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Auth",
      "auth": {
        "type": "noauth"
      },
      "item": [
        {
          "name": "Login as Seed Admin",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Correlation-ID",
                "value": "{{correlationId}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is OK\", function () {",
                  "  pm.expect(pm.response.code).to.eql(200);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test(\"Login returned access token\", function () {",
                  "  pm.expect(json.token && json.token.accessToken).to.exist;",
                  "});",
                  "if (json.token && json.token.accessToken) {",
                  "  pm.environment.set(\"accessToken\", json.token.accessToken);",
                  "}",
                  "if (json.token && json.token.refreshToken) {",
                  "  pm.environment.set(\"refreshToken\", json.token.refreshToken);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Correlation-ID",
                "value": "{{correlationId}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/refresh-token",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "refresh-token"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is OK\", function () {",
                  "  pm.expect(pm.response.code).to.eql(200);",
                  "});",
                  "const json = pm.response.json();",
                  "if (json.token && json.token.accessToken) {",
                  "  pm.environment.set(\"accessToken\", json.token.accessToken);",
                  "}",
                  "if (json.token && json.token.refreshToken) {",
                  "  pm.environment.set(\"refreshToken\", json.token.refreshToken);",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
